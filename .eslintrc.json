{
  "extends": "next/core-web-vitals",
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": [
              "@/v0-*/**",
              "archive/**",
              "**/archive/**",
              "**/v0-*",
              "**/v0-*/**",
              "../../v0-*",
              "../v0-*"
            ],
            "message": "Disallowed import path. Use src project modules only."
          }
        ]
      }
    ]
  }
}
